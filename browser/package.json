{
  "name": "@vcdn/browser",
  "version": "0.1.4",
  "description": "Browser SDK for VCDN upload-service public API",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --sourcemap",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build && pnpm run typecheck"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@vcdn/sdk-shared": "^0.1.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.5.4"
  }
}